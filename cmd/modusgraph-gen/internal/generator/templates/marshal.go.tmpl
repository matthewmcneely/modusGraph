package {{.PackageName}}
{{$entity := .Entity}}
{{$name := .Entity.Name}}
{{- $scalars := nonSliceScalarFields .Entity.Fields}}
{{- $singularEdges := allSingularEdgeFields .Entity.Fields}}
{{- $multiEdges := allMultiEdgeFields .Entity.Fields}}
{{- $sliceFields := allSliceFields .Entity.Fields}}
{{- $needsTime := false}}
{{- range $scalars}}{{if contains .GoType "time."}}{{$needsTime = true}}{{end}}{{end}}
{{- range $sliceFields}}{{if contains .GoType "time."}}{{$needsTime = true}}{{end}}{{end}}
{{- $allMarshal := marshalFields .Entity.Fields}}
{{- $extImports := externalImports $allMarshal .Imports}}

import (
	"context"
	"encoding/json"
{{- if $needsTime}}
	"time"
{{- end}}

	"github.com/matthewmcneely/modusgraph"
{{range $extImports}}
	{{- if .Alias}}
	{{.Alias}} "{{.Path}}"
	{{- else}}
	"{{.Path}}"
	{{- end}}
{{- end}}
)

// {{lcFirst $name}}Reflectable is an all-exported mirror of {{$name}} that carries
// the same json and dgraph tags. It is used for dgman query building (tag
// introspection via QueryModel) and mutation payload (MutateModel). It is
// never populated during the query result path.
type {{lcFirst $name}}Reflectable struct {
	UID   string   `json:"uid,omitempty"`
	DType []string `json:"dgraph.type,omitempty" dgraph:"{{$name}}"`
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
	{{. | accessorName}} {{.GoType}} `json:"{{.Predicate}},omitempty"{{if .RawDgraphTag}} dgraph:"{{.RawDgraphTag}}"{{end}}`
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
	{{. | accessorName}} {{.GoType}} `json:"{{.Predicate}},omitempty"{{if .RawDgraphTag}} dgraph:"{{.RawDgraphTag}}"{{end}}`
{{- end}}
{{- range $multiEdges}}
	{{. | accessorName}} {{.GoType}} `json:"{{.Predicate}},omitempty"{{if .RawDgraphTag}} dgraph:"{{.RawDgraphTag}}"{{end}}`
{{- end}}
{{- range $sliceFields}}
	{{. | accessorName}} {{.GoType}} `json:"{{.Predicate}},omitempty"{{if .RawDgraphTag}} dgraph:"{{.RawDgraphTag}}"{{end}}`
{{- end}}
}

// ToReflectable returns a populated all-exported copy for dgman.
// On the query path only its reflect.Type is used (tag introspection).
// On the mutation path the full copy is passed through dgman's pipeline.
func (e *{{$name}}) ToReflectable() any {
	return &{{lcFirst $name}}Reflectable{
		UID:   e.UID,
		DType: e.DType,
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
{{- range $multiEdges}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
{{- range $sliceFields}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
	}
}

// FromReflectable copies UID and DType back from the mutated reflectable.
func (e *{{$name}}) FromReflectable(model any) {
	s := model.(*{{lcFirst $name}}Reflectable)
	e.UID = s.UID
	e.DType = s.DType
}

// MarshalJSON implements custom JSON marshaling for {{$name}},
// allowing private fields to be serialized using predicate names as keys.
func (e {{$name}}) MarshalJSON() ([]byte, error) {
	m := make(map[string]interface{})
	if e.UID != "" {
		m["uid"] = e.UID
	}
	if len(e.DType) > 0 {
		m["dgraph.type"] = e.DType
	}
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
	{{- if contains .GoType "time."}}
	if !e.{{.Name}}.IsZero() {
		m["{{.Predicate}}"] = e.{{.Name}}
	}
	{{- else if or (eq .GoType "string") (contains .GoType "enums.")}}
	if e.{{.Name}} != "" {
		m["{{.Predicate}}"] = e.{{.Name}}
	}
	{{- else if or (eq .GoType "int") (eq .GoType "int64") (eq .GoType "float64") (eq .GoType "float32")}}
	if e.{{.Name}} != 0 {
		m["{{.Predicate}}"] = e.{{.Name}}
	}
	{{- else if eq .GoType "bool"}}
	if e.{{.Name}} {
		m["{{.Predicate}}"] = e.{{.Name}}
	}
	{{- else}}
	m["{{.Predicate}}"] = e.{{.Name}}
	{{- end}}
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
	m["{{.Predicate}}"] = e.{{.Name}}
{{- end}}
{{- range $multiEdges}}
	if len(e.{{.Name}}) > 0 {
		m["{{.Predicate}}"] = e.{{.Name}}
	}
{{- end}}
{{- range $sliceFields}}
	if len(e.{{.Name}}) > 0 {
		m["{{.Predicate}}"] = e.{{.Name}}
	}
{{- end}}
	return json.Marshal(m)
}

// UnmarshalJSON implements custom JSON unmarshaling for {{$name}},
// allowing private fields to be populated directly from JSON keyed by
// predicate names (as returned by Dgraph).
func (e *{{$name}}) UnmarshalJSON(data []byte) error {
	var raw map[string]json.RawMessage
	if err := json.Unmarshal(data, &raw); err != nil {
		return err
	}
	if v, ok := raw["uid"]; ok {
		json.Unmarshal(v, &e.UID)
	}
	if v, ok := raw["dgraph.type"]; ok {
		json.Unmarshal(v, &e.DType)
	}
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
	if v, ok := raw["{{.Predicate}}"]; ok {
		json.Unmarshal(v, &e.{{.Name}})
	}
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
	if v, ok := raw["{{.Predicate}}"]; ok {
		json.Unmarshal(v, &e.{{.Name}})
	}
{{- end}}
{{- range $multiEdges}}
	if v, ok := raw["{{.Predicate}}"]; ok {
		json.Unmarshal(v, &e.{{.Name}})
	}
{{- end}}
{{- range $sliceFields}}
	if v, ok := raw["{{.Predicate}}"]; ok {
		json.Unmarshal(v, &e.{{.Name}})
	}
{{- end}}
	return nil
}

// ValidateWith validates the {{$name}} using a mirror struct with exported fields,
// allowing the validator to access private field values safely. All fields are
// included so that custom validators (registered by field name or type) work
// correctly. Fields with validate tags have their tags preserved on the mirror.
func (e *{{$name}}) ValidateWith(ctx context.Context, v modusgraph.StructValidator) error {
	type mirror struct {
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
	{{- if .ValidateTag}}
		{{. | accessorName}} {{.GoType}} `validate:"{{.ValidateTag}}"`
	{{- else}}
		{{. | accessorName}} {{.GoType}}
	{{- end}}
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
	{{- if .ValidateTag}}
		{{. | accessorName}} {{.GoType}} `validate:"{{.ValidateTag}}"`
	{{- else}}
		{{. | accessorName}} {{.GoType}}
	{{- end}}
{{- end}}
{{- range $multiEdges}}
	{{- if .ValidateTag}}
		{{. | accessorName}} {{.GoType}} `validate:"{{.ValidateTag}}"`
	{{- else}}
		{{. | accessorName}} {{.GoType}}
	{{- end}}
{{- end}}
{{- range $sliceFields}}
	{{- if .ValidateTag}}
		{{. | accessorName}} {{.GoType}} `validate:"{{.ValidateTag}}"`
	{{- else}}
		{{. | accessorName}} {{.GoType}}
	{{- end}}
{{- end}}
	}
	return v.StructCtx(ctx, mirror{
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
{{- range $multiEdges}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
{{- range $sliceFields}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
	})
}
