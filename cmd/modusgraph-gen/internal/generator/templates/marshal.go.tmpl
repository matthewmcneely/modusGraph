package {{.PackageName}}
{{$entity := .Entity}}
{{$name := .Entity.Name}}
{{- $scalars := nonSliceScalarFields .Entity.Fields}}
{{- $singularEdges := allSingularEdgeFields .Entity.Fields}}
{{- $multiEdges := allMultiEdgeFields .Entity.Fields}}
{{- $sliceFields := allSliceFields .Entity.Fields}}
{{- $needsTime := false}}
{{- range $scalars}}{{if contains .GoType "time."}}{{$needsTime = true}}{{end}}{{end}}
{{- range $sliceFields}}{{if contains .GoType "time."}}{{$needsTime = true}}{{end}}{{end}}
{{- $allMarshal := marshalFields .Entity.Fields}}
{{- $extImports := externalImports $allMarshal .Imports}}

import (
	"context"
	"encoding/json"
{{- if $needsTime}}
	"time"
{{- end}}

	"github.com/matthewmcneely/modusgraph"
{{range $extImports}}
	{{- if .Alias}}
	{{.Alias}} "{{.Path}}"
	{{- else}}
	"{{.Path}}"
	{{- end}}
{{- end}}
)

// {{lcFirst $name}}Reflectable is an all-exported copy of {{$name}} that dgman's
// reflectwalk can traverse for mutations. It carries the same json and dgraph
// tags so the Dgraph schema is identical.
type {{lcFirst $name}}Reflectable struct {
	UID   string   `json:"uid,omitempty"`
	DType []string `json:"dgraph.type,omitempty"`
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
	{{. | accessorName}} {{.GoType}} `json:"{{.Predicate}},omitempty"{{if .RawDgraphTag}} dgraph:"{{.RawDgraphTag}}"{{end}}`
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
	{{. | accessorName}} {{.GoType}} `json:"{{.Predicate}},omitempty"{{if .RawDgraphTag}} dgraph:"{{.RawDgraphTag}}"{{end}}`
{{- end}}
{{- range $multiEdges}}
	{{. | accessorName}} {{.GoType}} `json:"{{.Predicate}},omitempty"{{if .RawDgraphTag}} dgraph:"{{.RawDgraphTag}}"{{end}}`
{{- end}}
{{- range $sliceFields}}
	{{. | accessorName}} {{.GoType}} `json:"{{.Predicate}},omitempty"{{if .RawDgraphTag}} dgraph:"{{.RawDgraphTag}}"{{end}}`
{{- end}}
}

// ToReflectable returns an all-exported copy of {{$name}} that dgman can mutate.
func (e *{{$name}}) ToReflectable() any {
	return &{{lcFirst $name}}Reflectable{
		UID:   e.UID,
		DType: e.DType,
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
{{- range $multiEdges}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
{{- range $sliceFields}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
	}
}

// FromReflectable copies UID and DType back from the reflectable copy after mutation.
func (e *{{$name}}) FromReflectable(r any) {
	s := r.(*{{lcFirst $name}}Reflectable)
	e.UID = s.UID
	e.DType = s.DType
}

// UnmarshalJSON implements custom JSON unmarshaling for {{$name}},
// allowing private fields to be populated from Dgraph query responses.
func (e *{{$name}}) UnmarshalJSON(data []byte) error {
	var a {{lcFirst $name}}Reflectable
	if err := json.Unmarshal(data, &a); err != nil {
		return err
	}
	e.UID = a.UID
	e.DType = a.DType
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
	e.{{.Name}} = a.{{. | accessorName}}
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
	e.{{.Name}} = a.{{. | accessorName}}
{{- end}}
{{- range $multiEdges}}
	e.{{.Name}} = a.{{. | accessorName}}
{{- end}}
{{- range $sliceFields}}
	e.{{.Name}} = a.{{. | accessorName}}
{{- end}}
	return nil
}

// ValidateWith validates the {{$name}} using a mirror struct with exported fields,
// allowing the validator to access private field values safely. All fields are
// included so that custom validators (registered by field name or type) work
// correctly. Fields with validate tags have their tags preserved on the mirror.
func (e *{{$name}}) ValidateWith(ctx context.Context, v modusgraph.StructValidator) error {
	type mirror struct {
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
	{{- if .ValidateTag}}
		{{. | accessorName}} {{.GoType}} `validate:"{{.ValidateTag}}"`
	{{- else}}
		{{. | accessorName}} {{.GoType}}
	{{- end}}
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
	{{- if .ValidateTag}}
		{{. | accessorName}} {{.GoType}} `validate:"{{.ValidateTag}}"`
	{{- else}}
		{{. | accessorName}} {{.GoType}}
	{{- end}}
{{- end}}
{{- range $multiEdges}}
	{{- if .ValidateTag}}
		{{. | accessorName}} {{.GoType}} `validate:"{{.ValidateTag}}"`
	{{- else}}
		{{. | accessorName}} {{.GoType}}
	{{- end}}
{{- end}}
{{- range $sliceFields}}
	{{- if .ValidateTag}}
		{{. | accessorName}} {{.GoType}} `validate:"{{.ValidateTag}}"`
	{{- else}}
		{{. | accessorName}} {{.GoType}}
	{{- end}}
{{- end}}
	}
	return v.StructCtx(ctx, mirror{
{{- range $scalars}}{{if not .IsUID}}{{if not .IsDType}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}{{end}}{{end}}
{{- range $singularEdges}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
{{- range $multiEdges}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
{{- range $sliceFields}}
		{{. | accessorName}}: e.{{.Name}},
{{- end}}
	})
}
