package {{ .EntityPackageName }}

{{- $E := .Entity.Name }}
{{- $fields := nonSliceScalarFields .Entity.Fields }}

{{- $needsTime := false }}
{{- range $fields }}{{ if contains .GoType "time." }}{{ $needsTime = true }}{{ end }}{{ end }}
{{- $extImports := externalImports $fields .Imports }}

{{ if or $needsTime (gt (len $extImports) 0) -}}
import (
{{- if $needsTime }}
	"time"
{{- end }}
{{ range $extImports }}
	{{- if .Alias }}
	{{ .Alias }} "{{ .Path }}"
	{{- else }}
	"{{ .Path }}"
	{{- end }}
{{ end }}
)
{{ end }}

// {{ $E }}Option configures a *{{ $E }}. Applied at construction time via
// New{{ $E }} or Wrap{{ $E }}, or in bulk later via Apply{{ $E }}Options.
type {{ $E }}Option func(*{{ $E }})

// Apply{{ $E }}Options applies a sequence of options to e in order.
func Apply{{ $E }}Options(e *{{ $E }}, opts ...{{ $E }}Option) {
	for _, opt := range opts {
		opt(e)
	}
}

{{- range $fields }}
  {{- if and (not .IsUID) (not .IsDType) }}

// With{{ $E }}{{ . | accessorName }} sets the {{ .JSONTag }} field on a *{{ $E }}.
func With{{ $E }}{{ . | accessorName }}(v {{ .GoType }}) {{ $E }}Option {
	return func(e *{{ $E }}) { e.Set{{ . | accessorName }}(v) }
}
  {{- end }}
{{- end }}
