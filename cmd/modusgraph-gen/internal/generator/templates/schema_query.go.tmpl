package {{ .Pkg.Name }}

import (
	"context"

	"github.com/matthewmcneely/modusgraph"
)

{{- $E := .Entity.Name }}

// {{ $E }}Query is a fluent query builder for {{ $E }} records. Terminal
// methods (Nodes, First) execute the query against the underlying
// modusgraph.Client and populate raw *{{ $E }} results.
type {{ $E }}Query struct {
	ctx  context.Context
	conn modusgraph.Client
}

// New{{ $E }}Query constructs a query bound to ctx and conn. Callers
// usually obtain one via {{ $E }}Client.Query rather than directly.
func New{{ $E }}Query(ctx context.Context, conn modusgraph.Client) *{{ $E }}Query {
	return &{{ $E }}Query{ctx: ctx, conn: conn}
}

// Nodes executes the query and decodes results into recs. recs must be a
// pointer to a []{{ $E }} or []*{{ $E }} slice.
func (q *{{ $E }}Query) Nodes(recs any) error {
	return q.conn.Query(q.ctx, &{{ $E }}{}).Nodes(recs)
}

// First runs the query with implicit Limit=1 and returns the first
// {{ $E }} record, or nil if the query yielded no rows.
func (q *{{ $E }}Query) First() (*{{ $E }}, error) {
	var recs []{{ $E }}
	if err := q.Nodes(&recs); err != nil {
		return nil, err
	}
	if len(recs) == 0 {
		return nil, nil
	}
	return &recs[0], nil
}
