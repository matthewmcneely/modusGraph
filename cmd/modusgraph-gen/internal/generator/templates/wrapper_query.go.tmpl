package {{ .EntityPackageName }}

import (
	"github.com/matthewmcneely/modusgraph/typed"

	"{{ .SchemaImportPath }}"
)

{{- $E := .Entity.Name }}
{{- $sAlias := .SchemaAlias }}

// {{ $E }}Query is the wrapper-side fluent query builder for {{ $E }}. Builder
// methods return *{{ $E }}Query for chaining; terminal methods (Nodes, First)
// execute the query and wrap results.
type {{ $E }}Query struct {
	typed *typed.Query[{{ $sAlias }}.{{ $E }}]
}

// Filter adds a dgraph @filter expression. params bind to placeholders.
func (q *{{ $E }}Query) Filter(filter string, params ...any) *{{ $E }}Query {
	q.typed.Filter(filter, params...)
	return q
}

// OrderAsc orders results ascending by clause.
func (q *{{ $E }}Query) OrderAsc(clause string) *{{ $E }}Query {
	q.typed.OrderAsc(clause)
	return q
}

// OrderDesc orders results descending by clause.
func (q *{{ $E }}Query) OrderDesc(clause string) *{{ $E }}Query {
	q.typed.OrderDesc(clause)
	return q
}

// Limit caps the number of results.
func (q *{{ $E }}Query) Limit(n int) *{{ $E }}Query {
	q.typed.Limit(n)
	return q
}

// Offset skips the first n results.
func (q *{{ $E }}Query) Offset(n int) *{{ $E }}Query {
	q.typed.Offset(n)
	return q
}

// After returns results with UID greater than uid (cursor pagination).
func (q *{{ $E }}Query) After(uid string) *{{ $E }}Query {
	q.typed.After(uid)
	return q
}

// Cascade drops nodes missing any of the given predicates.
func (q *{{ $E }}Query) Cascade(predicates ...string) *{{ $E }}Query {
	q.typed.Cascade(predicates...)
	return q
}

// Nodes executes the query and returns wrapped {{ $E }} results.
func (q *{{ $E }}Query) Nodes() ([]*{{ $E }}, error) {
	recs, err := q.typed.Nodes()
	if err != nil {
		return nil, err
	}
	out := make([]*{{ $E }}, len(recs))
	for i := range recs {
		out[i] = Wrap{{ $E }}(&recs[i])
	}
	return out, nil
}

// First executes the query with an implicit Limit(1) and returns the first
// wrapped {{ $E }}, or nil if no rows matched.
func (q *{{ $E }}Query) First() (*{{ $E }}, error) {
	s, err := q.typed.First()
	if err != nil || s == nil {
		return nil, err
	}
	return Wrap{{ $E }}(s), nil
}
