package {{ .Pkg.Name }}

import (
	"context"

	"github.com/matthewmcneely/modusgraph"
)

{{- $E := .Entity.Name }}

// {{ $E }}Client provides CRUD/query operations over {{ $E }} records.
// Takes and returns *{{ $E }} directly — no wrapper allocation.
type {{ $E }}Client struct {
	conn modusgraph.Client
}

// New{{ $E }}Client binds a {{ $E }}Client to conn.
func New{{ $E }}Client(conn modusgraph.Client) *{{ $E }}Client {
	return &{{ $E }}Client{conn: conn}
}

// Get loads the {{ $E }} with the given UID.
func (c *{{ $E }}Client) Get(ctx context.Context, uid string) (*{{ $E }}, error) {
	var rec {{ $E }}
	if err := c.conn.Get(ctx, &rec, uid); err != nil {
		return nil, err
	}
	return &rec, nil
}

// Add inserts a new {{ $E }}.
func (c *{{ $E }}Client) Add(ctx context.Context, s *{{ $E }}) error {
	return c.conn.Insert(ctx, s)
}

// Update modifies an existing {{ $E }} (must have UID set).
func (c *{{ $E }}Client) Update(ctx context.Context, s *{{ $E }}) error {
	return c.conn.Update(ctx, s)
}

// Upsert inserts or updates a {{ $E }}, matching against predicates. If no
// predicates are provided, the first field tagged dgman:"upsert" wins.
func (c *{{ $E }}Client) Upsert(ctx context.Context, s *{{ $E }}, predicates ...string) error {
	return c.conn.Upsert(ctx, s, predicates...)
}

// Delete removes the {{ $E }} with the given UID.
func (c *{{ $E }}Client) Delete(ctx context.Context, uid string) error {
	return c.conn.Delete(ctx, []string{uid})
}

// Query returns a query builder for {{ $E }}, allowing further refinement
// before execution.
func (c *{{ $E }}Client) Query(ctx context.Context) *{{ $E }}Query {
	return New{{ $E }}Query(ctx, c.conn)
}
